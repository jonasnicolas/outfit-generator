# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenRouter API key — powers AI outfit generation via Gemini 2.5 Flash Image.
# LOCAL DEV: set VITE_OPENROUTER_API_KEY here; the browser calls OpenRouter directly.
VITE_OPENROUTER_API_KEY=your_openrouter_api_key

# DEPLOYED (e.g. Vercel): do NOT set the VITE_ var above. Instead set a
# server-only secret named OPENROUTER_API_KEY in your host's env settings. The
# app then routes through the /api/generate serverless proxy and the key never
# reaches the browser.
# OPENROUTER_API_KEY=your_openrouter_api_key
